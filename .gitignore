
# ========================================
# SmartOutfitAdvisor - .gitignore
# ========================================

# 环境变量和配置文件（含敏感信息）
.env
.env.local
.env.*.local

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db

# 数据文件（可选保留，根据需要）
data/*.db
data/generated_images/*.png
data/generated_images/*.jpg
data/user_*.json

# Streamlit
.streamlit/secrets.toml

# 日志文件
*.log

# 临时文件
tmp/
temp/

# 构建产物
*.bak
*.tmp

# 前端构建（如果有）
node_modules/
dist/

